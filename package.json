{
  "name": "pipos-backend",
  "version": "1.0.0",
  "description": "Aplikasi Kasir Multi-Tenant SaaS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch ./src/ --watch ./node_modules src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate:master": "knex migrate:latest --migrations-directory ./migrations/master",
    "migrate:master-rollback": "knex migrate:rollback --migrations-directory ./migrations/master",
    "migrate:master-make": "knex migrate:make --migrations-directory ./migrations/master",
    "migrate:tenant": "node ./scripts/migrate_tenants.js",
    "migrate:tenant-rollback": "node ./scripts/migrate_tenants.js --rollback",
    "migrate:tenant-make": "knex migrate:make --migrations-directory ./migrations/tenant"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "file-type": "^22.0.1",
    "joi": "^18.0.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "midtrans-client": "^1.4.3",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
